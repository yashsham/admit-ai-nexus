# --- Core App ---
ENVIRONMENT=development
VITE_API_URL=http://localhost:8000/api

# --- Database (Supabase) ---
# Required for both Frontend and Backend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- AI & LLM Services ---
# Primary LLM
VITE_GROQ_API_KEY=
GROQ_API_KEY=

# Fallback & Vision
GOOGLE_API_KEY=

# Agent & Orchestration
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# Search Tools
VITE_TAVILY_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# --- Communication Channels ---

# Email (SMTP Credentials - Fails on Render Free Tier due to port blocks)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Email (HTTP APIs - Works 100% on Render Free Tier and bypasses firewalls)
FROM_EMAIL=noreply@admitai.com
SENDGRID_API_KEY=
RESEND_API_KEY=
BREVO_API_KEY=

# Gmail HTTP REST API via OAuth2 (100% Free, bypasses firewall, real Gmail sender)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Google Apps Script Web App Relay (100% Free, bypasses firewall, real Gmail sender)
GOOGLE_APPS_SCRIPT_URL=

# WhatsApp & SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Meta WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Voice (Retell AI)
RETELL_API_KEY=
RETELL_AGENT_ID=

# --- LangChain Tracing (Optional) ---
VITE_LANGCHAIN_TRACING_V2=true
VITE_LANGCHAIN_API_KEY=
VITE_LANGCHAIN_PROJECT=
